---
import MainLayout from '@/layout/MainLayout.astro';
import GalleryHeader from '@/gallery/GalleryHeader.astro';
import GalleryGrid from '@/gallery/GalleryGrid.astro';
import CtaSection from '@/shared/CtaSection.astro';
---

<MainLayout title="Nala the Astronaut - Gallery">
  <GalleryHeader />
  <GalleryGrid />
  <CtaSection
    eyebrow="More to come"
    title="Check back soon"
    body="We're always adding new photos from Nala's adventures. In the meantime, get to know her a little better."
    href="/about"
    label="Learn more about Nala"
  />
</MainLayout>
