---
import MainLayout from '@/layout/MainLayout.astro';
import AboutHero from '@/about/AboutHero.astro';
import QuickFacts from '@/about/QuickFacts.astro';
import AboutStory from '@/about/AboutStory.astro';
import Achievements from '@/about/Achievements.astro';
import CtaSection from '@/shared/CtaSection.astro';
---

<MainLayout title="About Nala - Nala the Astronaut">
  <AboutHero />
  <QuickFacts />
  <AboutStory />
  <Achievements />
  <CtaSection
    eyebrow="See her in action"
    title="Ready for more Nala?"
    body="Head over to the gallery for a growing collection of the cutest golden retriever in the galaxy."
    href="/gallery"
    label="Visit the gallery"
  />
</MainLayout>
