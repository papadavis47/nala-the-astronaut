---
const traits = [
    {
        icon: "🎾",
        title: "Fetch enthusiast",
        body: "Will retrieve a ball from any distance — or ignore it entirely, her call.",
    },
    {
        icon: "🛋️",
        title: "Couch connoisseur",
        body: "Has personally tested and approved every soft surface in the house.",
    },
    {
        icon: "🍖",
        title: "Treat negotiator",
        body: "Deploys elite puppy eyes for maximum snack acquisition.",
    },
    {
        icon: "👃",
        title: "Chief greeter",
        body: "No visitor gets past the door without a thorough sniff inspection.",
    },
    {
        icon: "🐿️",
        title: "Squirrel patrol",
        body: "Keeps the backyard safe from all suspicious wildlife activity.",
    },
    {
        icon: "💛",
        title: "Heart thief",
        body: "Has stolen every heart in the household, and most of the visitors' too.",
    },
];
---

<section class="w-full flex justify-center bg-surface border-y border-border">
    <div
        class="w-full max-w-5xl lg:max-w-[85vw] 2xl:max-w-[1400px] px-6 lg:px-8 py-16 md:py-24"
    >
        <div class="text-center mb-10 reveal">
            <p
                class="text-sm font-semibold uppercase tracking-widest text-gold mb-4"
            >
                In short
            </p>
            <h2 class="text-3xl md:text-4xl font-bold">A few of her talents</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 reveal">
            {
                traits.map(({ icon, title, body }) => (
                    <div class="bg-background rounded-2xl p-6 border border-border shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                        <span class="text-3xl block mb-3">{icon}</span>
                        <h3 class="font-display font-bold text-lg mb-2">
                            {title}
                        </h3>
                        <p class="text-muted">{body}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
